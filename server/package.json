{
  "name": "qr-event-attendance-server",
  "version": "1.0.0",
  "description": "Backend API for QR Event Attendance System",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seed.ts",
    "db:seed:demo": "tsx src/database/seed.demo.ts",
    "db:seed:mini": "tsx src/database/seed.mini.ts",
    "db:seed:staff": "tsx src/database/seed.staff.ts",
    "db:seed:prime": "tsx src/database/seed.prime.ts",
    "db:seed:adsc": "tsx src/database/seed.adsc.ts",
    "db:migrate:branches": "tsx src/database/migrate_branches.ts"
  },
  "keywords": [
